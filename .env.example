# Copy this file to ".env" and fill in your keys. Both are OPTIONAL:
# the bulk pipeline produces the full dataset without either key.

# USPTO Open Data Portal (api.uspto.gov) — used to add the most recent years
# and assignee (company) names. Register: https://account.uspto.gov/api-manager/
USPTO_API_KEY=

# US Census Bureau — used for per-capita normalisation (patents per 100k people).
# Free instant key: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Counting method override: "fractional" (default) or "whole"
# AEROSPACE_COUNTING=fractional
